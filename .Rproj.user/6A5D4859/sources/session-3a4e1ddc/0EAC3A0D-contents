[build]
  publish = "_site"
  command = """
  apt-get update
  
  # Install required tools
  apt-get install -y wget dpkg
  
  # Install Quarto
  wget https://github.com/quarto-dev/quarto-cli/releases/download/v1.5.57/quarto-1.5.57-linux-amd64.deb
  dpkg -i quarto-1.5.57-linux-amd64.deb
  
  # Render
  quarto render
  """