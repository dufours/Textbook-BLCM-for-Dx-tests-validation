library(ggplot2)
library(patchwork)
# ---------------------------------
# Shared conceptual data
# ---------------------------------
df <- data.frame(
x = c(rep(0, 3), rep(1, 5)),
y = c(3:1, 4:0),
label = c(
"Disease A", "Disease B", "Disease C",
"Fever", "Cough", "Rash", "Angina", "Splenomegaly"
)
)
# ---------------------------------
# Frequentist / Deductive panel
# ---------------------------------
p_freq <- ggplot(df, aes(x, y)) +
geom_text(aes(label = label), size = 4) +
geom_segment(
aes(x = 0.15, xend = 0.85, y = 4.5, yend = 4.5),
arrow = arrow(length = unit(0.25, "cm"))
) +
annotate("text", x = 0.5, y = 5.0,
label = "Deduction",
size = 4.5, fontface = "bold") +
annotate("text", x = 0, y = 5.7,
label = "Putative\nunderlying diseases",
size = 4, fontface = "bold") +
annotate("text", x = 1, y = 5.7,
label = "Observed\nsymptoms",
size = 4, fontface = "bold") +
ggtitle("Frequentist inference") +
scale_x_continuous(limits = c(-0.4, 1.4)) +
scale_y_continuous(limits = c(-1.5, 6)) +
theme_void() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.margin = margin(20, 20, 20, 20)
)
# ---------------------------------
# Bayesian / Inductive panel
# ---------------------------------
p_bayes <- ggplot(df, aes(x, y)) +
geom_text(aes(label = label), size = 4) +
geom_segment(
aes(x = 0.85, xend = 0.15, y = -1.0, yend = -1.0),
arrow = arrow(length = unit(0.25, "cm"))
) +
annotate("text", x = 0.5, y = -1.5,
label = "Induction",
size = 4.5, fontface = "bold") +
annotate("text", x = 0, y = 5.7,
label = "Putative\nunderlying diseases",
size = 4, fontface = "bold") +
annotate("text", x = 1, y = 5.7,
label = "Observed\nsymptoms",
size = 4, fontface = "bold") +
ggtitle("Bayesian inference") +
scale_x_continuous(limits = c(-0.4, 1.4)) +
scale_y_continuous(limits = c(-2, 6)) +
theme_void() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.margin = margin(20, 20, 20, 20)
)
# ---------------------------------
# Combine panels
# ---------------------------------
p_freq | p_bayes
