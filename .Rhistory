set.seed(123)
n_samples <- 20
n_per_sample <- 200
true_prev <- 0.15
dat <- do.call(rbind, lapply(1:n_samples, function(i) {
y <- rbinom(n_per_sample, 1, true_prev)
p_hat <- mean(y)
se <- sqrt(p_hat * (1 - p_hat) / n_per_sample)
data.frame(
sample = i,
estimate = p_hat,
lower = p_hat - 1.96 * se,
upper = p_hat + 1.96 * se
)
}))
``
View(dat)
library(ggplot2)
ggplot(dat, aes(x = sample, y = estimate * 100)) +
# Confidence intervals
geom_errorbar(
aes(ymin = lower * 100, ymax = upper * 100),
width = 0.15,
color = "black"
) +
# Point estimates
geom_point(
aes(color = factor(sample)),
size = 2.5
) +
# True prevalence
geom_hline(
yintercept = true_prev * 100,
linetype = "dashed",
linewidth = 0.6
) +
annotate(
"text",
x = n_samples + 0.7,
y = true_prev * 100,
label = "True prevalence",
hjust = 0,
size = 4,
fontface = "italic"
) +
scale_x_continuous(breaks = 1:n_samples) +
scale_y_continuous(limits = c(11, 19)) +
labs(
x = "Sample",
y = "Prevalence (%)"
) +
theme_classic() +
theme(
legend.position = "none",
axis.title = element_text(size = 12, face = "bold")
)
ggplot(dat, aes(x = sample, y = estimate * 100)) +
# Confidence intervals
